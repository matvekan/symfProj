{% extends 'base.html.twig' %}

{% block title %}Registration{% endblock %}

{% block stylesheets %}
<style>
body { font-family: Arial, sans-serif; background: #f3f5f7; margin: 0; }
.wrap { max-width: 520px; margin: 40px auto; background: #fff; border: 1px solid #ddd; border-radius: 8px; padding: 18px; }
h1 { margin: 0 0 14px 0; font-size: 22px; }
label { display: block; font-size: 13px; margin: 8px 0 4px; }
input { width: 100%; padding: 8px; box-sizing: border-box; }
button { margin-top: 12px; width: 100%; padding: 10px; }
.msg { margin-top: 10px; font-size: 13px; min-height: 18px; color: #0b6b00; }
.msg.error { color: #b10000; }
a { display: inline-block; margin-top: 10px; }
</style>
{% endblock %}

{% block body %}
<div class="wrap">
    <h1>Registration</h1>
    <label>Name</label>
    <input id="name" value="" placeholder="Enter name">
    <label>Email</label>
    <input id="email" type="email" value="" placeholder="Enter email">
    <label>Password</label>
    <input id="password" type="password" value="" placeholder="Enter password">
    <label>Created at (optional, format: YYYY-MM-DD HH:mm:ss)</label>
    <input id="createdAt" value="">
    <label>interestIds (optional, comma separated)</label>
    <input id="interestIds" value="">
    <button id="registerBtn">Create account</button>
    <a href="/">Back to login</a>
    <div id="msg" class="msg"></div>
</div>

<script>
const msg = document.getElementById('msg');

function parseIds(v) {
    return v.split(',').map(x => x.trim()).filter(Boolean).map(Number).filter(Number.isFinite);
}

async function register() {
    msg.textContent = '';
    msg.classList.remove('error');

    const payload = {
        name: document.getElementById('name').value.trim(),
        email: document.getElementById('email').value.trim(),
        password: document.getElementById('password').value,
        interestIds: parseIds(document.getElementById('interestIds').value),
    };

    const createdAt = document.getElementById('createdAt').value.trim();
    if (createdAt) payload.created_at = createdAt;

    const response = await fetch('/api/auth/register', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(payload),
    });

    const text = await response.text();
    let data = {};
    try { data = JSON.parse(text); } catch (e) { data = {message: text}; }

    if (!response.ok) {
        msg.classList.add('error');
        msg.textContent = data.error || data.message || 'Registration failed';
        return;
    }

    msg.textContent = 'Registration successful. Redirecting to login...';
    setTimeout(() => { window.location.href = '/'; }, 900);
}

document.getElementById('registerBtn').addEventListener('click', register);
</script>
{% endblock %}
