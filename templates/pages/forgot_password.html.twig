{% extends 'base.html.twig' %}

{% block title %}Forgot Password{% endblock %}

{% block stylesheets %}
<style>
body { font-family: Arial, sans-serif; background: #f3f5f7; margin: 0; }
.wrap { max-width: 620px; margin: 30px auto; background: #fff; border: 1px solid #ddd; border-radius: 8px; padding: 18px; }
h1 { margin: 0 0 14px 0; font-size: 22px; }
h2 { margin: 18px 0 8px; font-size: 17px; }
label { display: block; font-size: 13px; margin: 8px 0 4px; }
input { width: 100%; padding: 8px; box-sizing: border-box; }
button { margin-top: 10px; width: 100%; padding: 10px; }
.msg { margin-top: 10px; font-size: 13px; min-height: 18px; }
a { display: inline-block; margin-top: 12px; }
</style>
{% endblock %}

{% block body %}
<div class="wrap">
    <h1>Password Recovery</h1>

    <h2>Step 1: Request token</h2>
    <label>Email</label>
    <input id="email" type="email" value="" placeholder="Enter your email">
    <button id="requestBtn">Send reset token</button>

    <h2>Step 2: Reset password</h2>
    <label>Token (from email link or from Mailpit in dev)</label>
    <input id="token" value="">
    <label>New password</label>
    <input id="newPassword" type="password" value="" placeholder="Enter new password">
    <button id="resetBtn">Update password</button>

    <a href="/">Back to login</a>
    <div id="msg" class="msg"></div>
</div>

<script>
const msg = document.getElementById('msg');

async function requestToken() {
    msg.textContent = '';
    const email = document.getElementById('email').value.trim();
    const response = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ email }),
    });
    const data = await response.json();
    msg.textContent = data.message || data.error || 'Done';
}

async function resetPassword() {
    msg.textContent = '';
    const token = document.getElementById('token').value.trim();
    const newPassword = document.getElementById('newPassword').value;
    const response = await fetch('/api/auth/reset-password', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ token, newPassword }),
    });
    const data = await response.json();
    msg.textContent = data.message || data.error || 'Done';
}

document.getElementById('requestBtn').addEventListener('click', requestToken);
document.getElementById('resetBtn').addEventListener('click', resetPassword);

const queryToken = new URLSearchParams(window.location.search).get('token');
if (queryToken) {
    document.getElementById('token').value = queryToken;
}
</script>
{% endblock %}
